%!PS
/pinst 500 array def
/pop_ucache 100 array def
systemdict /ucache get pop_ucache exch 0 exch put
systemdict /pop get pop_ucache exch 1 exch put
pinst 1 pop_ucache put

/impl 100 dict def
impl /Implementation [pinst] put

(setpattern test: ) print flush
{
  impl setpattern
  (ok\n) print flush
} stopped {
  (stopped caught: ) print flush
  count 0 gt { dup type 20 string cvs print ( ) print flush } if
  $error /errorname known {
    $error /errorname get 30 string cvs print
  } if
  (\n) print flush
  % clear stack
  count { pop } repeat
} if

{ [/DeviceGray] setcolorspace } stopped { pop } if
quit
