%!PS
% Check if zpop is actually being called on 8.71
% Use 'add' instead of 'pop' — if called with fake i_ctx, it will
% try to read two operands from the fake op_stack and add them.
% If it crashes or modifies something, we know the function is reached.

/pinst 500 array def
/pop_ucache 100 array def

% Test 1: use zpop, check operand stack depth change
systemdict /ucache get pop_ucache exch 0 exch put
systemdict /pop get pop_ucache exch 1 exch put
pinst 1 pop_ucache put
/impl 100 dict def
impl /Implementation [pinst] put

(Stack depth before: ) print count 10 string cvs print (\n) print flush
42 43 44  % push 3 markers
(Stack depth with markers: ) print count 10 string cvs print (\n) print flush
{ impl setpattern } stopped { pop } if
(Stack depth after setpattern: ) print count 10 string cvs print (\n) print flush
% Print what's left on stack
count { dup type 20 string cvs print (=) print 20 string cvs print ( ) print } repeat
(\n) print flush

{ [/DeviceGray] setcolorspace } stopped { pop } if
quit
