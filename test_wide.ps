%!PS
/pinst 500 array def
/pop_ucache 100 array def
systemdict /ucache get pop_ucache exch 0 exch put
systemdict /pop get pop_ucache exch 1 exch put
pinst 1 pop_ucache put
/impl 100 dict def
impl /Implementation [pinst] put

% Scan positions 2-250 one at a time
2 1 250 {
  /pos exch def
  /pa 32767 array def
  pa 0 77777 put
  pinst pos pa put
  { impl setpattern } stopped { pop } if
  /hit false def
  pinst pos get wcheck not { /hit true def } if
  pinst pos get pa eq not { /hit true def } if
  hit {
    (HIT pos=) print pos 10 string cvs print
    pinst pos get wcheck { ( w=t) } { ( w=f) } ifelse print
    pinst pos get pa eq { ( eq=t) } { ( eq=f) } ifelse print
    (\n) print flush
  } if
  pinst pos null put
  { [/DeviceGray] setcolorspace } stopped { pop } if
} for
(Scan complete.\n) print flush
quit
